local FLY_WALK_SPEED    = 200
local FLY_ASCEND_SPEED  = 50
local FLY_DESCEND_SPEED = 50
local FLY_TURN_SPEED    = 0.15
local hkFlying            = false
local hkFlyAttach     = nil
