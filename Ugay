            local beam = player.PlayerScripts:FindFirstChild("CharacterAndBeamMove")
            if beam then beam.Disabled = true end
        end
        task.wait(0.1)
    end
end)

local hkAutoLagEnabled = true
local hkLastFpsCheck = tick()
local hkFpsFrames = 0

RunService.Heartbeat:Connect(function()
    if not hkAutoLagEnabled then return end
    hkFpsFrames += 1
    local now = tick()
    if now - hkLastFpsCheck >= 1 then
        local fps = hkFpsFrames / (now - hkLastFpsCheck)
        hkFpsFrames = 0
        hkLastFpsCheck = now
        if fps <= hkFpsThreshold and not hkAntiLagOn then
            hkSetAntiLag(true)
            OrionLib:MakeNotification({ Name = "Auto Anti-Lag", Content = "FPS dropped to "..math.floor(fps).." (threshold: "..hkFpsThreshold..") — Anti-Lag enabled", Time = 3 })
        elseif fps > hkFpsThreshold and hkAntiLagOn then
            hkSetAntiLag(false)
            OrionLib:MakeNotification({ Name = "Auto Anti-Lag", Content = "FPS recovered to "..math.floor(fps).." — Anti-Lag disabled", Time = 3 })
        end
    end
end)

