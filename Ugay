local hkLastTap      = 0
local DOUBLE_TAP_TIME   = 0.3
local hkSpaceDown         = false
local function setFlying(enabled)
    hkFlying = enabled
    if enabled then
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hkFlyHum:ChangeState(Enum.HumanoidStateType.Running)
        hkFlyAttach = Instance.new("Attachment")
        hkFlyAttach.Parent = hkFlyRoot
        hkFlyVel = Instance.new("LinearVelocity")
        hkFlyVel.Attachment0 = hkFlyAttach
        hkFlyVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        hkFlyVel.MaxForce = math.huge
        hkFlyVel.RelativeTo = Enum.ActuatorRelativeTo.World
        hkFlyVel.VectorVelocity = Vector3.zero
        hkFlyVel.Parent = hkFlyRoot
    else
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        hkFlyHum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        if hkFlyVel then hkFlyVel:Destroy(); hkFlyVel = nil end
        if hkFlyAttach then hkFlyAttach:Destroy(); hkFlyAttach = nil end
        hkFlyHum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end
