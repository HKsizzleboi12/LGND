function hkDeployToy(targetPlr, typee)
    local myToys = workspace:FindFirstChild(player.Name.."SpawnedInToys")
    if not myToys then return end
    if not myToys:FindFirstChild(targetPlr.Name) then
        if targetPlr.Character and targetPlr.Character.Parent and targetPlr.Character.Parent.Name == "Workspace" then
            if typee == 1 then
                local hkToy = hkSpawnPencil(targetPlr)
                if hkToy ~= "Nigga" then hkStickyTorso(targetPlr, hkToy) end
            else
                local hkToy = hkSpawnNinja(targetPlr)
                if hkToy ~= "Nigga" then hkStickyLeg(targetPlr, hkToy) end
            end
        end
    else
        local hkItem = myToys:FindFirstChild(targetPlr.Name)
        hkCleanupToy(targetPlr, hkItem)
    end
end
