            if player.Character and player:FindFirstChild("CanSpawnToy") and player.CanSpawnToy.Value and not hkAGSt then
                hkAGSt = tick()
                task.spawn(function()
                    game.ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer(
                        "InstrumentWoodwindOcarina",
                        CFrame.new(1e5, 1e5, 1e5),
                        Vector3.new(0, 0, 0)
