local function fmtAge(days)
    if days>=365 then return math.floor(days/365).."yr "..math.floor((days%365)/30).."mo"
    elseif days>=30 then return math.floor(days/30).."mo"
    else return days.."d" end
end
local httpFunc=nil
pcall(function()
    if syn and syn.request then httpFunc=syn.request
    elseif http_request then httpFunc=http_request
    elseif request then httpFunc=request
    elseif http and http.request then httpFunc=http.request end
end)
local function tryGet(url)
    if httpFunc then
        local ok,r=pcall(httpFunc,{Url=url,Method="GET"})
        if ok and r and r.Body and #r.Body>2 then return r.Body end
    end
    local ok2,r2=pcall(function() return game:HttpGet(url) end)
    if ok2 and r2 and #r2>2 then return r2 end
    return nil
end
local function tryPost(url,body)
    if not httpFunc then return nil end
    local ok,r=pcall(httpFunc,{Url=url,Method="POST",Headers={["Content-Type"]="application/json"},Body=body})
    if ok and r and r.Body then return r.Body end
    return nil
end
local function jd(s)
    if not s then return nil end
    local ok,v=pcall(HttpService.JSONDecode,HttpService,s)
    return ok and v or nil
end
