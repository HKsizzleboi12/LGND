local hkAntiLagOn = false
local hkFpsThreshold = 30 

local function hkSetAntiLag(value)
    hkAntiLagOn = value
    _G.AntiLag = value
    if hkAntiLagRef then hkAntiLagRef:Set(value) end
end

task.spawn(function()
    while true do
