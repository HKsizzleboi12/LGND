function hkBlobService()
    while true do
        local hkListMode = 1
        if hkKickAll or hkKillAll then hkListMode = 2 end
        hkBlobRunning = false
        for _,plr in pairs(Players:GetPlayers()) do
            if hkBringTargets[plr.UserId] and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and hkIsGrabbed(plr.Character) then
                if hkBringTargets[plr.UserId] == "none" or hkBringTargets[plr.UserId] == "crip" or not hkBringTargets[plr.UserId] or hkBringTargets[plr.UserId] == "bris" then
                    if hkBringTargets[plr.UserId] == "crip" then
                        plr.Character.Humanoid.WalkSpeed = 0
                    end
                    hkBringTargets[plr.UserId] = nil
                else
                    plr.Character.HumanoidRootPart.CFrame = hkBringTargets[plr.UserId]
                    plr.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    hkBringTargets[plr.UserId] = nil
                    if hkKickTargets[plr.UserId] or (hkKickAll and (hkKickFriendWL and not Players.LocalPlayer:IsFriendsWith(plr.UserId) or not hkKickFriendWL)) then
                        hkAction = "Kick"
                    end
                end
            elseif hkKickTargets[plr.UserId] or hkKillTargets[plr.UserId] or hkBringTargets[plr.UserId] or hkKickAll or hkKillAll then
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    j = player.Character.HumanoidRootPart.CFrame
                    h = player.Character.HumanoidRootPart.AssemblyLinearVelocity
                end
                local hkAction = nil
                if hkBringTargets[plr.UserId] and hkBringTargets[plr.UserId] ~= "bris" then
                    hkAction = "Bring"
                elseif hkKillTargets[plr.UserId] or hkBringTargets[plr.UserId] == "bris" then
                    hkAction = "Kill"
                elseif hkKickTargets[plr.UserId] then
                    hkAction = "Kick"
                else
                    if hkKickAll then
                        if hkKickFriendWL then
                            if not hkFriendIds[plr.UserId] then hkAction = "Kick" end
                        else hkAction = "Kick" end
                    end
                    if hkKillAll then
                        if hkKillFriendWL then
                            if not hkFriendIds[plr.UserId] then hkAction = "Kill" end
                        else hkAction = "Kill" end
                    end
                end
                if plr ~= player and hkAction then
                    local continue = false
                    if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                        if plr.Character.HumanoidRootPart.Massless then
                            if plr.Character.Humanoid.SeatPart then continue = true end
                        else continue = true end
                    end
                    local hkActive = true
                    while hkActive and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and plr and plr.Character and (hkAction == "Kick" or hkAction == "Kill" or hkAction == "Bring") and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character.HumanoidRootPart.CFrame.Position.Magnitude < 1000000 and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid:GetState() ~= Enum.HumanoidStateType.Dead and continue do
                        if hkListMode == 2 then
                            if not hkKickAll and not hkKillAll then hkActive = false
                            elseif hkFriendIds[plr.UserId] then hkActive = false end
                        else
                            if not hkKickTargets[plr.UserId] and not hkKillTargets[plr.UserId] and not hkBringTargets[plr.UserId] then hkActive = false end
                        end
                        hkBlobRunning = true
                        continue = true
                        local vel = plr.Character.HumanoidRootPart.AssemblyLinearVelocity
                        if plr.Character.HumanoidRootPart.AssemblyLinearVelocity.Magnitude > 10000 then vel = Vector3.zero end
                        if hkActive and continue and player.Character and player.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid:GetState() ~= Enum.HumanoidStateType.Dead and player.Character.Humanoid.SeatPart and player.Character.Humanoid.SeatPart.Parent and player.Character.Humanoid.SeatPart.Parent.Name == "CreatureBlobman" then
                            hkExpectingBlob = true
                            hkBlob = player.Character.Humanoid.SeatPart.Parent
                            if hkBlob:FindFirstChild("HumanoidCreature") then hkBlob.HumanoidCreature.PlatformStand = true end
                            if hkBlob:WaitForChild("RightDetector",.5) and hkBlob.RightDetector:WaitForChild("RightWeld",.5) then
                                player.Character.HumanoidRootPart.CFrame = (plr.Character:FindFirstChild("HumanoidRootPart").CFrame * CFrame.new(0,-20,10)) + (plr.Character:FindFirstChild("HumanoidRootPart").AssemblyLinearVelocity / math.pi)
                                player.Character.HumanoidRootPart.AssemblyLinearVelocity = plr.Character:FindFirstChild("HumanoidRootPart").AssemblyLinearVelocity
                                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                                    if hkAction == "Bring" then
                                        if plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health ~= 0 and hkBlob and hkBlob:FindFirstChild("RightDetector") and hkBlob.RightDetector:FindFirstChild("RightWeld") and hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript") and hkBlob.BlobmanSeatAndOwnerScript:FindFirstChild("CreatureGrab") and hkBlob.BlobmanSeatAndOwnerScript:FindFirstChild("CreatureRelease") then
                                            if hkIsGrabbed(plr.Character) then
                                                if hkBringTargets[plr.UserId] == "none" or hkBringTargets[plr.UserId] == "crip" or not hkBringTargets[plr.UserId] then
                                                    plr.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                                                    if hkBringTargets[plr.UserId] == "crip" then plr.Character.Humanoid.WalkSpeed = 0 end
                                                    hkBringTargets[plr.UserId] = nil
                                                else
                                                    plr.Character.HumanoidRootPart.CFrame = hkBringTargets[plr.UserId]
                                                    plr.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                                                    hkBringTargets[plr.UserId] = nil
                                                    if hkKickTargets[plr.UserId] or (hkKickAll and (hkKickFriendWL and not Players.LocalPlayer:IsFriendsWith(plr.UserId) or not hkKickFriendWL)) then hkAction = "Kick" end
                                                end
                                            else
                                                hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript").CreatureGrab:FireServer(hkBlob.RightDetector,plr.Character.HumanoidRootPart,hkBlob.RightDetector.RightWeld)
                                                hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript").CreatureRelease:FireServer(hkBlob.RightDetector.RightWeld,plr.Character.HumanoidRootPart)
                                            end
                                        end
                                    elseif hkAction == "Kick" then
                                        if plr.Character.Parent == workspace then
                                            game.ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(plr.Character.HumanoidRootPart,plr.Character.HumanoidRootPart.CFrame)
                                            plr.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,10^10,0)
                                            game.ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(plr.Character.HumanoidRootPart)
                                            hkBlob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(hkBlob.RightDetector,plr.Character.HumanoidRootPart,hkBlob.RightDetector.RightWeld)
                                            hkBlob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(hkBlob.RightDetector,player.Character.HumanoidRootPart,hkBlob.RightDetector.RightWeld)
                                            hkBlob.BlobmanSeatAndOwnerScript.CreatureDrop:FireServer(hkBlob.RightDetector["RightWeld"],player.Character.HumanoidRootPart)
                                        else
                                            hkBringTargets[plr.UserId] = CFrame.new(-73,-6,-265.5)
                                            hkActive = false
                                        end
                                    else
                                        if plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health ~= 0 and hkBlob and hkBlob:FindFirstChild("RightDetector") and hkBlob.RightDetector:FindFirstChild("RightWeld") and hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript") and hkBlob.BlobmanSeatAndOwnerScript:FindFirstChild("CreatureGrab") and hkBlob.BlobmanSeatAndOwnerScript:FindFirstChild("CreatureRelease") then
                                            if hkBringTargets[plr.UserId] == "bris" then hkBringTargets[plr.UserId] = nil end
                                            plr.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Dead)
                                            hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript").CreatureGrab:FireServer(hkBlob.RightDetector,plr.Character.HumanoidRootPart,hkBlob.RightDetector.RightWeld)
                                            hkBlob:FindFirstChild("BlobmanSeatAndOwnerScript").CreatureRelease:FireServer(hkBlob.RightDetector.RightWeld,plr.Character.HumanoidRootPart)
                                        end
                                    end
                                end
                            else
                                game.ReplicatedStorage.MenuToys.DestroyToy:FireServer(workspace:FindFirstChild(player.Name.."SpawnedInToys"):FindFirstChild("CreatureBlobman") or hkPlot and workspace.PlotItems[hkPlot]:FindFirstChild("CreatureBlobman"))
                            end
                        elseif continue then
                            hkExpectingBlob = true
                            if player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.SeatPart and (player.Character.Humanoid.SeatPart.Parent and player.Character.Humanoid.SeatPart.Parent.Name ~= "CreatureBlobman" or not player.Character.Humanoid.SeatPart.Parent) then
                                player.Character.Humanoid.Sit = false
                            end
                            if hkBlob and hkBlob:FindFirstChild("VehicleSeat") then
                                if player.Character and player.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid:GetState() ~= Enum.HumanoidStateType.Dead then
                                    hkBlob.VehicleSeat:Sit(player.Character.Humanoid)
                                end
                            else
                                hkFoundBlob = false
                                hkBlob = nil
                                for _,itm in pairs(workspace[player.Name.."SpawnedInToys"]:GetChildren()) do
                                    if itm.Name == "CreatureBlobman" and itm:FindFirstChild("VehicleSeat") then
                                        if hkBlob and hkBlob:WaitForChild("RightDetector",.5) and hkBlob.RightDetector:WaitForChild("RightWeld",.5) then
                                            hkFoundBlob = true
                                            hkBlob = itm
                                        else
                                            game.ReplicatedStorage.MenuToys.DestroyToy:FireServer(workspace:FindFirstChild(player.Name.."SpawnedInToys"):FindFirstChild("CreatureBlobman") or hkPlot and workspace.PlotItems[hkPlot]:FindFirstChild("CreatureBlobman"))
                                        end
                                    elseif itm.Name == "CreatureBlobman" then
                                        game.ReplicatedStorage.MenuToys.DestroyToy:FireServer(itm)
                                        task.wait(0.1)
                                    end
                                end
                                if hkBlob and player.Character and player.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid:GetState() ~= Enum.HumanoidStateType.Dead then
                                    hkBlob.VehicleSeat:Sit(player.Character.Humanoid)
                                end
                                if not hkFoundBlob then
                                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                                        if player.Character.Parent ~= workspace and player.Character:FindFirstChild("HumanoidRootPart") then
                                            player.Character.HumanoidRootPart.CFrame = CFrame.new(0,-10,0)
                                            player.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
                                        end
                                        while hkActive and not hkBlob do
                                            if hkListMode == 2 then
                                                if not hkKickAll and not hkKillAll then hkActive = false
                                                elseif hkFriendIds[plr.UserId] then hkActive = false end
                                            else
                                                if not (hkKickTargets[plr.UserId] or hkKillTargets[plr.UserId] or hkBringTargets[plr.UserId]) then hkActive = false end
                                            end
                                            if workspace:FindFirstChild(player.Name.."SpawnedInToys"):FindFirstChild("CreatureBlobman") or hkPlot and workspace.PlotItems[hkPlot]:FindFirstChild("CreatureBlobman") then
                                                hkBlob = workspace:FindFirstChild(player.Name.."SpawnedInToys"):FindFirstChild("CreatureBlobman") or workspace.PlotItems[hkPlot]:FindFirstChild("CreatureBlobman")
                                                if not (hkBlob:WaitForChild("RightDetector",.5) and hkBlob:FindFirstChild("RightDetector") and hkBlob.RightDetector:WaitForChild("RightWeld",.5)) then
                                                    game.ReplicatedStorage.MenuToys.DestroyToy:FireServer(workspace:FindFirstChild(player.Name.."SpawnedInToys"):FindFirstChild("CreatureBlobman") or hkPlot and workspace.PlotItems[hkPlot]:FindFirstChild("CreatureBlobman"))
                                                end
                                            end
                                            if not hkBlob then
                                                task.spawn(function()
                                                    game.ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer("CreatureBlobman",CFrame.new(player.Character.HumanoidRootPart.CFrame.Position)+Vector3.new(0,0,15),Vector3.new(0,0,0))
                                                end)
                                            end
                                            task.wait()
                                        end
                                    end
                                end
                            end
                        end
                        task.wait()
                    end
                end
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = j
                    player.Character.HumanoidRootPart.AssemblyLinearVelocity = h
                end
            end
        end
        if not hkBlobRunning and hkBlob then
            if player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.SeatPart and player.Character.Humanoid.SeatPart.Parent == hkBlob then
                player.Character.Humanoid.Sit = false
            end
            task.wait()
            if hkBlob and hkBlob:FindFirstChild("HumanoidRootPart") then
                hkBlob.HumanoidRootPart.CFrame = CFrame.new(0,1e15,0)
            end
        end
        hkExpectingBlob = false
        task.wait()
    end
end
